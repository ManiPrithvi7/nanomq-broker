# =============================================================================
# Railway — NanoMQ (standalone project: nanomq-broker/)
# Option B: mTLS on 8883 via env vars — RECOMMENDED for production
# =============================================================================
# Do NOT commit real PEMs. Paste into Railway → Variables only.
# Tip: use the Raw editor (</>) so line breaks are preserved. If PEMs arrive as one line
# with literal \n, docker-entrypoint.sh expands them before writing files.
# Optional: NANOMQ_DEBUG_CERTS=1 to log SHA256, SANs, chain verify at container start (then remove).
# Optional: NANOMQ_LOG_LEVEL=info (or debug) for one deploy — surfaces SSL listener lines in NanoMQ logs.
#
# Do NOT set NANOMQ_TLS_ENABLE (this deployment uses nanomq.conf, not that flag).
#
# Production mTLS:
#   • Omit NANOMQ_DISABLE_TLS (or unset).
#   • Set NANOMQ_TLS_CA_CERT, NANOMQ_TLS_CERT, NANOMQ_TLS_KEY (full PEM text).
#   • Networking → Public TCP Proxy → map external port → container 8883.
#
# Staging (plain MQTT only — NOT for public production):
#   • NANOMQ_DISABLE_TLS=1
#   • TCP proxy → container 1883
# =============================================================================

NANOMQ_TLS_CA_CERT="-----BEGIN CERTIFICATE-----
REPLACE_WITH_root-ca.crt
-----END CERTIFICATE-----"

NANOMQ_TLS_CERT="-----BEGIN CERTIFICATE-----
REPLACE_WITH_broker.crt
-----END CERTIFICATE-----"

NANOMQ_TLS_KEY="-----BEGIN PRIVATE KEY-----
REPLACE_WITH_broker.key
-----END PRIVATE KEY-----"

# -----------------------------------------------------------------------------
# mqtt-publisher-lite (separate Railway service) — connect with same Root CA + app client cert
# -----------------------------------------------------------------------------
# MQTT_BROKER=<railway-tcp-public-hostname>
# MQTT_PORT=<railway-tcp-external-port-mapped-to-8883>
# MQTT_TLS_ENABLED=true
# MQTT_TLS_CA_PATH=/path/to/root-ca.crt   (or use *_PEM / *_BASE64 in app config if supported)
# MQTT_TLS_CLIENT_CERT_PATH=.../server-mqtt-client.crt
# MQTT_TLS_CLIENT_KEY_PATH=.../server-mqtt-client.key
# MQTT_TLS_SERVERNAME=<CN on broker.crt if hostname ≠ CN>

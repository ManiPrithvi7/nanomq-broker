# Proof-v3 — Ubuntu 24.04 (NanoMQ 0.24.13 needs GLIBC >= 2.36); update OCID/IP after launch
export OCI_CLI_PROFILE=DEFAULT
export OCI_COMPARTMENT_ID=ocid1.tenancy.oc1..aaaaaaaaewvfhp2zsnrelgtosfrob63q24urtghb624ehgweteoowpmgt5xa
export OCI_INSTANCE_NAME=Proof-v3
export OCI_INSTANCE_ID=
export OCI_PUBLIC_IP=
# Key pair from OCI Console download (must match instance launch pubkey)
export OCI_SSH_KEY="${HOME}/Downloads/ssh-key-2026-06-02.key"
# ubuntu for Ubuntu images; opc for Oracle Linux
export OCI_SSH_USER=ubuntu
export OCI_ASSIGN_PUBLIC_IP=1
export OCI_ENSURE_IGW_ROUTE=1
export CA_DIR="/home/statsnapp/Desktop/proofmqtt/data/ca"
# Deploy broker leaf: ./deploy-certs.sh ubuntu@IP ~/Desktop/proofmqtt/broker/certs
# Uses root-ca-nanomq.crt (openssl re-sign of root-ca.crt for NanoMQ mbedtls)
# export SKIP_NETWORK=1

# IMPORTANT: NanoMQ 0.24.13 needs GLIBC >= 2.33 — Ubuntu 22.04+ or Oracle Linux 9 (not Ubuntu 20.04).

# Copy to .env for docker compose (optional overrides).
# Default: broker PEMs are read from ./certs/ + ROOT_CA_CRT volume mount.

# Path to Root CA PEM (mounted into nanomq-broker as root_ca.crt)
ROOT_CA_CRT=../statsmqtt/data/ca/root-ca.crt

# Optional debug (one-off local troubleshooting)
# NANOMQ_DEBUG_CERTS=1
# NANOMQ_LOG_LEVEL=info

# Alternative to volume mounts: paste output of ./print-railway-broker-env.sh
# (entrypoint prefers env vars when all three are non-empty)
# NANOMQ_TLS_CA_CERT=
# NANOMQ_TLS_CERT=
# NANOMQ_TLS_KEY=
